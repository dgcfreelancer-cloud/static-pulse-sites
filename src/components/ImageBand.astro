---
const {
  src,
  alt,
  label,
  title,
  text,
  reverse = false,
} = Astro.props;
---

<section class="section">
  <div class={`container image-band ${reverse ? 'image-band-reverse' : ''}`}>
    <div class="image-band-copy">
      {label && <p class="eyebrow">{label}</p>}
      <h2>{title}</h2>
      {text && <p class="lead">{text}</p>}
    </div>

    <div class="image-band-frame">
      <img src={src} alt={alt} />
    </div>
  </div>
</section>