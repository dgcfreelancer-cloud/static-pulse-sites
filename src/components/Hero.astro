---
const {
  eyebrow,
  title,
  text,
  primaryText,
  primaryHref,
  secondaryText,
  secondaryHref,
} = Astro.props;
---

<section class="hero-section">
  <div class="container hero-grid">
    <div class="hero-content">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}

      <h1>{title}</h1>

      {text && <p class="lead hero-lead">{text}</p>}

      <div class="button-row">
        {primaryText && primaryHref && (
          <a class="btn btn-primary" href={primaryHref}>{primaryText}</a>
        )}

        {secondaryText && secondaryHref && (
          <a class="btn btn-secondary" href={secondaryHref}>{secondaryText}</a>
        )}
      </div>
    </div>

    <div class="hero-panel" aria-hidden="true">
      <div class="code-card">
        <p class="code-label">STATIC // BUILD</p>
        <pre><code>&lt;site&gt;
  speed="fast"
  plugins="none"
  ownership="true"
/&gt;</code></pre>
      </div>
    </div>
  </div>
</section>