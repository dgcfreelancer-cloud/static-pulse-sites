---
const {
  eyebrow,
  title,
  text,
  primaryText,
  primaryHref,
  secondaryText,
  secondaryHref,
} = Astro.props;
---

<section class="hero-section">
  <div class="container">
    <div class="hero-content">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}

      <h1>{title}</h1>

      {text && <p class="lead hero-lead">{text}</p>}

      <div class="button-row">
        {primaryText && primaryHref && (
          <a class="btn btn-primary" href={primaryHref}>
            {primaryText}
          </a>
        )}

        {secondaryText && secondaryHref && (
          <a class="btn btn-secondary" href={secondaryHref}>
            {secondaryText}
          </a>
        )}
      </div>
    </div>
  </div>
</section>